{
  "name": "@enjoys/monaco-vanced",
  "version": "0.2.0",
  "type": "module",
  "description": "A plugin-based, event-driven IDE built on Monaco Editor",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "import": "./dist/core/*.mjs",
      "require": "./dist/core/*.cjs"
    },
    "./core/events": {
      "types": "./dist/core/events/index.d.ts",
      "import": "./dist/core/events/index.mjs",
      "require": "./dist/core/events/index.cjs"
    },
    "./editor/*": {
      "types": "./dist/plugins/editor/*/index.d.ts",
      "import": "./dist/plugins/editor/*/index.mjs",
      "require": "./dist/plugins/editor/*/index.cjs"
    },
    "./language/*": {
      "types": "./dist/plugins/language/*/index.d.ts",
      "import": "./dist/plugins/language/*/index.mjs",
      "require": "./dist/plugins/language/*/index.cjs"
    },
    "./filesystem/*": {
      "types": "./dist/plugins/filesystem/*/index.d.ts",
      "import": "./dist/plugins/filesystem/*/index.mjs",
      "require": "./dist/plugins/filesystem/*/index.cjs"
    },
    "./layout/*": {
      "types": "./dist/plugins/layout/*/index.d.ts",
      "import": "./dist/plugins/layout/*/index.mjs",
      "require": "./dist/plugins/layout/*/index.cjs"
    },
    "./ai/*": {
      "types": "./dist/plugins/ai/*/index.d.ts",
      "import": "./dist/plugins/ai/*/index.mjs",
      "require": "./dist/plugins/ai/*/index.cjs"
    },
    "./scm/*": {
      "types": "./dist/plugins/scm/*/index.d.ts",
      "import": "./dist/plugins/scm/*/index.mjs",
      "require": "./dist/plugins/scm/*/index.cjs"
    },
    "./devtools/*": {
      "types": "./dist/plugins/devtools/*/index.d.ts",
      "import": "./dist/plugins/devtools/*/index.mjs",
      "require": "./dist/plugins/devtools/*/index.cjs"
    },
    "./extensions/*": {
      "types": "./dist/plugins/extensions/*/index.d.ts",
      "import": "./dist/plugins/extensions/*/index.mjs",
      "require": "./dist/plugins/extensions/*/index.cjs"
    },
    "./theming/*": {
      "types": "./dist/plugins/theming/*/index.d.ts",
      "import": "./dist/plugins/theming/*/index.mjs",
      "require": "./dist/plugins/theming/*/index.cjs"
    },
    "./infrastructure/*": {
      "types": "./dist/plugins/infrastructure/*/index.d.ts",
      "import": "./dist/plugins/infrastructure/*/index.mjs",
      "require": "./dist/plugins/infrastructure/*/index.cjs"
    },
    "./platform/*": {
      "types": "./dist/plugins/platform/*/index.d.ts",
      "import": "./dist/plugins/platform/*/index.mjs",
      "require": "./dist/plugins/platform/*/index.cjs"
    },
    "./enterprise/*": {
      "types": "./dist/plugins/enterprise/*/index.d.ts",
      "import": "./dist/plugins/enterprise/*/index.mjs",
      "require": "./dist/plugins/enterprise/*/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ plugins/ core/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "monaco",
    "editor",
    "ide",
    "plugin",
    "vscode",
    "code-editor",
    "web-ide",
    "typescript",
    "lsp",
    "ai",
    "copilot",
    "extensions",
    "theming",
    "collaboration",
    "git",
    "terminal",
    "debugger"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/dot-object": "^2.1.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "dexie": "^4.4.2",
    "dot-object": "^2.1.5",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vscode-icons-js": "^11.6.1",
    "zustand": "^5.0.12"
  }
}
