{
  "name": "GitHub Light",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#24292f",
    "editor.selectionBackground": "#0969da33",
    "editor.lineHighlightBackground": "#f6f8fa",
    "editorCursor.foreground": "#24292f",
    "editorWhitespace.foreground": "#d0d7de",
    "editorIndentGuide.background": "#d0d7de",
    "editorLineNumber.foreground": "#8c959f",
    "editorLineNumber.activeForeground": "#24292f",
    "editor.findMatchBackground": "#bf8700",
    "editor.findMatchHighlightBackground": "#fae17d80",
    "editorBracketMatch.background": "#0969da20",
    "editorBracketMatch.border": "#0969da"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#6e7781", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#0a3069" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#0550ae" } },
    { "scope": ["constant.language"], "settings": { "foreground": "#0550ae" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#cf222e" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#cf222e" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#8250df" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#953800" } },
    { "scope": ["variable", "variable.parameter"], "settings": { "foreground": "#24292f" } },
    { "scope": ["variable.other.constant"], "settings": { "foreground": "#0550ae" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#116329" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#0550ae" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#24292f" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#0550ae", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } }
  ]
}
